---
import { Icon } from "astro-icon/components";
---

<main class="relative min-h-screen flex items-center justify-center bg-[#08080A] overflow-hidden">
    <!-- Background Effects -->
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-cyan-900/10 blur-[120px] rounded-full pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-blue-900/10 blur-[120px] rounded-full pointer-events-none"></div>

    <div class="relative z-10 w-full max-w-md p-8">
        <div class="bg-[#121214]/80 backdrop-blur-xl border border-white/10 rounded-2xl p-8 shadow-2xl relative overflow-hidden group">
            <!-- Holographic Border -->
            <div class="absolute inset-0 bg-gradient-to-br from-cyan-500/10 via-transparent to-blue-500/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
            
            <div class="text-center mb-8">
                <div class="inline-flex p-3 rounded-xl bg-cyan-500/10 mb-4">
                    <Icon name="lucide:lock" class="w-8 h-8 text-cyan-400" />
                </div>
                <h1 class="text-2xl font-bold text-white mb-2">Bienvenido a MBC</h1>
                <p class="text-gray-400 text-sm">Ingrese sus credenciales para acceder al panel</p>
            </div>

            <form id="login-form" class="space-y-6">
                <div>
                    <label for="email" class="block text-sm font-medium text-gray-300 mb-2">Correo Electrónico</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <Icon name="lucide:mail" class="w-5 h-5 text-gray-500" />
                        </div>
                        <input 
                            type="email" 
                            id="email" 
                            name="email" 
                            class="block w-full pl-10 pr-3 py-3 bg-[#08080A] border border-white/10 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-colors"
                            placeholder="usuario@ejemplo.com"
                            required
                        />
                    </div>
                </div>

                <div>
                    <label for="password" class="block text-sm font-medium text-gray-300 mb-2">Contraseña</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <Icon name="lucide:key" class="w-5 h-5 text-gray-500" />
                        </div>
                        <input 
                            type="password" 
                            id="password" 
                            name="password" 
                            class="block w-full pl-10 pr-3 py-3 bg-[#08080A] border border-white/10 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-colors"
                            placeholder="••••••••"
                            required
                        />
                    </div>
                </div>

                <div id="error-message" class="hidden text-red-400 text-sm text-center bg-red-500/10 p-2 rounded-lg border border-red-500/20">
                    Credenciales incorrectas
                </div>

                <button 
                    type="submit" 
                    class="w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-gradient-to-r from-cyan-600 to-blue-600 hover:from-cyan-500 hover:to-blue-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-cyan-500 transition-all duration-300 transform hover:scale-[1.02]"
                >
                    Iniciar Sesión
                </button>
            </form>
        </div>
    </div>
</main>

<script>
    import { signInWithEmail } from '../lib/authSession';

    const form = document.getElementById('login-form') as HTMLFormElement | null;
    const errorMsg = document.getElementById('error-message');
    const btnSubmit = document.querySelector('button[type="submit"]') as HTMLButtonElement | null;

    if (form) {
        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const formData = new FormData(form);
            const email = (formData.get('email') as string).trim();
            const password = formData.get('password') as string;

            if (errorMsg) errorMsg.classList.add('hidden');
            if (btnSubmit) { btnSubmit.disabled = true; btnSubmit.textContent = 'Verificando...'; }

            try {
                const result = await signInWithEmail(email, password);

                if (!result.success || !result.session) {
                    if (errorMsg) {
                        errorMsg.textContent = result.error ?? 'Credenciales incorrectas';
                        errorMsg.classList.remove('hidden');
                    }
                    return;
                }

                // Supabase maneja la persistencia de sesión automáticamente.
                // Guardamos datos de perfil en localStorage para acceso sincrónico
                // en la UI (nombre, rol) sin necesidad de llamadas async.
                localStorage.setItem('mbc_session', JSON.stringify({
                    user:    result.session.user,
                    role:    result.session.role,
                    email:   result.session.email,
                }));

                window.location.href = '/dashboard';

            } catch {
                if (errorMsg) {
                    errorMsg.textContent = 'No se pudo conectar al servidor';
                    errorMsg.classList.remove('hidden');
                }
            } finally {
                if (btnSubmit) { btnSubmit.disabled = false; btnSubmit.textContent = 'Iniciar Sesión'; }
            }
        });
    }
</script>