---
import { Icon } from "astro-icon/components";
import AceleracionWidget from './islands/AceleracionWidget';
import FFTChart from './islands/FFTChart';
import ConnectionStatus from './islands/ConnectionStatus';
import SensorSummaryCard from './islands/SensorSummaryCard';
import DaqControlPanel from './islands/DaqControlPanel';
import VelocidadWidget from './islands/VelocidadWidget';
import OrbitaXYWidget from './islands/OrbitaXYWidget';
import TendenciaVRMSWidget from './islands/TendenciaVRMSWidget';
import HistoricoWidget from './islands/HistoricoWidget';

// Mock Data para reportes
const REPORTS = [
    { id: 1, title: "Reporte Mensual de Vibraciones - Enero", date: "2024-01-31", size: "2.4 MB" },
    { id: 2, title: "Análisis de Falla - Molino 1", date: "2024-02-15", size: "5.1 MB" },
    { id: 3, title: "Certificación de Sensores", date: "2024-03-01", size: "1.2 MB" },
];

// Sensores para la vista de monitoreo (tabla)
const SENSORS = [
    { id: 1, name: "P1-ZARANDA", status: "normal", temp: 65, vibration: 2.4 },
    { id: 2, name: "P2-ZARANDA", status: "warning", temp: 82, vibration: 4.1 },
    { id: 3, name: "P3-ZARANDA", status: "critical", temp: 95, vibration: 8.5 },
    { id: 4, name: "P4-ZARANDA", status: "normal", temp: 55, vibration: 1.2 },
];
---

<script is:inline>
    (function() {
        const session = localStorage.getItem('mbc_session');
        if (!session) {
            window.location.href = '/login';
        }
    })();
</script>

<div id="dashboard-app" class="min-h-screen bg-[#08080A] flex hidden opacity-0 transition-opacity duration-500 relative overflow-hidden">
        <!-- Mobile Overlay -->
        <div id="sidebar-overlay" class="fixed inset-0 bg-black/60 z-40 hidden lg:hidden backdrop-blur-sm transition-opacity"></div>

        <!-- Sidebar -->
        <aside id="sidebar" class="fixed lg:static inset-y-0 left-0 z-50 w-64 bg-[#121214] border-r border-white/5 flex flex-col shrink-0 transform -translate-x-full lg:translate-x-0 transition-transform duration-300">
            <div class="p-6 border-b border-white/5">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded bg-gradient-to-br from-cyan-500 to-blue-600 flex items-center justify-center text-white font-bold">M</div>
                    <span class="text-white font-bold tracking-wide">MBC PANEL</span>
                </div>
            </div>
            
            <nav class="flex-1 p-4 space-y-2 mt-6">
                <button id="nav-dashboard" class="w-full flex items-center gap-3 px-4 py-3 bg-cyan-500/10 text-cyan-400 rounded-lg border border-cyan-500/20 transition-colors">
                    <Icon name="lucide:layout-dashboard" class="w-5 h-5" />
                    <span>Dashboard</span>
                </button>
                <button id="nav-monitoring" class="w-full flex items-center gap-3 px-4 py-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-colors">
                    <Icon name="lucide:activity" class="w-5 h-5" />
                    <span>Monitoreo</span>
                </button>
                <button id="nav-reports" class="w-full flex items-center gap-3 px-4 py-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-colors">
                    <Icon name="lucide:file-text" class="w-5 h-5" />
                    <span>Reportes</span>
                </button>
                <button id="nav-settings" class="hidden w-full flex items-center gap-3 px-4 py-3 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-colors">
                    <Icon name="lucide:settings" class="w-5 h-5" />
                    <span>Configuración</span>
                </button>
            </nav>

            <div class="p-4 border-t border-white/5">
                <div class="flex items-center gap-3 mb-4 px-2">
                    <div class="w-10 h-10 rounded-full bg-gray-800 flex items-center justify-center text-gray-400">
                        <Icon name="lucide:user" class="w-5 h-5" />
                    </div>
                    <div>
                        <p id="user-name" class="text-sm font-medium text-white">Usuario</p>
                        <p id="user-role" class="text-xs text-gray-500 capitalize">Rol</p>
                    </div>
                </div>
                <button id="logout-btn" class="w-full flex items-center justify-center gap-2 px-4 py-2 bg-red-500/10 text-red-400 border border-red-500/20 rounded-lg hover:bg-red-500/20 transition-colors text-sm">
                    <Icon name="lucide:log-out" class="w-4 h-4" />
                    <span>Cerrar Sesión</span>
                </button>
            </div>
        </aside>

        <!-- Main Content Wrapper -->
        <div class="flex-1 flex flex-col min-w-0 h-screen overflow-hidden">
            <!-- Main Content -->
            <main class="flex-1 p-4 md:p-8 overflow-y-auto overflow-x-hidden">
                <!-- VIEW: DASHBOARD -->
                <div id="view-dashboard">
                    <header class="flex flex-col md:flex-row md:justify-between items-start md:items-center mb-6 md:mb-8 gap-4">
                        <div class="flex items-center gap-3">
                            <button id="menu-toggle-dash" class="menu-toggle lg:hidden text-gray-400 hover:text-white p-1 rounded-md bg-white/5 border border-white/10">
                                <Icon name="lucide:menu" class="w-6 h-6" />
                            </button>
                            <div>
                                <h1 class="text-xl md:text-2xl font-bold text-white leading-tight">Zaranda Movil</h1>
                                <p class="text-gray-400 text-xs md:text-sm mt-1">Monitoreo en tiempo real</p>
                            </div>
                        </div>
                    <div class="flex items-center gap-4 w-full md:w-auto overflow-x-auto pb-1">
                        <!-- Estado de conexión al backend (React Island) -->
                        <ConnectionStatus client:load />
                    </div>
                </header>

                <!-- ═══════════════════════════════════════════════ -->
                <!-- CONTROL DAQ — Iniciar/Detener adquisición      -->
                <!-- ═══════════════════════════════════════════════ -->
                <div class="mb-8">
                    <DaqControlPanel client:load />
                </div>

                <!-- ═══════════════════════════════════════════════ -->
                <!-- RESUMEN DE SENSOR — Accel / Stroke / RPM / Phase -->
                <!-- ═══════════════════════════════════════════════ -->
                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 mb-8">
                    <SensorSummaryCard client:load sensorName="P1-ZARANDA" sensorId="Nodo 1 · 33190" nodeId={1} />
                    <SensorSummaryCard client:load sensorName="P2-ZARANDA" sensorId="Nodo 2 · 33191" nodeId={2} />
                    <SensorSummaryCard client:load sensorName="P3-ZARANDA" sensorId="Nodo 3 · 33192" nodeId={3} />
                    <SensorSummaryCard client:load sensorName="P4-ZARANDA" sensorId="Nodo 4 · 33193" nodeId={4} />
                </div>

                <!-- ═══════════════════════════════════════════════ -->
                <!-- WIDGETS EN TIEMPO REAL (React Islands)         -->
                <!-- ═══════════════════════════════════════════════ -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
                    <!-- Aceleración G — Series de Tiempo (ocupa 2 columnas) -->
                    <div class="lg:col-span-2 min-w-0">
                        <AceleracionWidget client:load />
                    </div>

                    <!-- Espectro FFT (ocupa 2 columnas) -->
                    <div class="lg:col-span-2 min-w-0">
                        <FFTChart client:load />
                    </div>

                    <!-- Velocidad Instantánea y VRMS (ocupa 2 columnas) -->
                    <div class="lg:col-span-2 min-w-0">
                        <VelocidadWidget client:load />
                    </div>

                    <!-- Órbita XY -->
                    <div class="min-w-0">
                        <OrbitaXYWidget client:load />
                    </div>

                    <!-- Tendencia VRMS -->
                    <div class="min-w-0">
                        <TendenciaVRMSWidget client:load />
                    </div>

                    <!-- Histórico HDF5 (ocupa 2 columnas) -->
                    <div class="lg:col-span-2 min-w-0">
                        <HistoricoWidget client:load />
                    </div>
                </div>
            </div>

            <!-- VIEW: MONITORING -->
            <div id="view-monitoring" class="hidden">
                <header class="flex flex-col sm:flex-row sm:items-center gap-3 justify-between mb-6 md:mb-8">
                    <div class="flex items-center gap-3">
                        <button id="menu-toggle-mon" class="menu-toggle lg:hidden text-gray-400 hover:text-white p-1 rounded-md bg-white/5 border border-white/10">
                            <Icon name="lucide:menu" class="w-6 h-6" />
                        </button>
                    <div>
                        <h1 class="text-xl md:text-2xl font-bold text-white leading-tight">Monitoreo Detallado</h1>
                        <p class="text-gray-400 text-xs md:text-sm mt-1">Vista tabular de todos los sensores activos</p>
                    </div>
                </header>
                
                <div class="bg-[#121214] border border-white/5 rounded-xl overflow-x-auto">
                    <table class="w-full text-left text-sm text-gray-400 min-w-[600px]">
                        <thead class="bg-white/5 text-white font-medium">
                            <tr>
                                <th class="p-4">ID</th>
                                <th class="p-4">Activo</th>
                                <th class="p-4">Estado</th>
                                <th class="p-4">Temperatura</th>
                                <th class="p-4">Vibración</th>
                                <th class="p-4">Última Actualización</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/5">
                            {SENSORS.map(sensor => (
                                <tr class="hover:bg-white/5 transition-colors">
                                    <td class="p-4">#{sensor.id}</td>
                                    <td class="p-4 text-white">{sensor.name}</td>
                                    <td class="p-4">
                                        <span class={`px-2 py-1 rounded text-xs font-medium border ${
                                            sensor.status === 'critical' ? 'bg-red-500/10 text-red-400 border-red-500/20' : 
                                            sensor.status === 'warning' ? 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20' : 
                                            'bg-green-500/10 text-green-400 border-green-500/20'
                                        }`}>
                                            {sensor.status.toUpperCase()}
                                        </span>
                                    </td>
                                    <td class="p-4">{sensor.temp}°C</td>
                                    <td class="p-4">{sensor.vibration} mm/s</td>
                                    <td class="p-4 sensor-update-time">--</td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- VIEW: REPORTS -->
            <div id="view-reports" class="hidden">
                <header class="flex flex-col sm:flex-row sm:items-center gap-3 justify-between mb-6 md:mb-8">
                    <div class="flex items-center gap-3">
                        <button id="menu-toggle-rep" class="menu-toggle lg:hidden text-gray-400 hover:text-white p-1 rounded-md bg-white/5 border border-white/10">
                            <Icon name="lucide:menu" class="w-6 h-6" />
                        </button>
                        <div>
                            <h1 class="text-xl md:text-2xl font-bold text-white leading-tight">Reportes Técnicos</h1>
                            <p class="text-gray-400 text-xs md:text-sm mt-1">Descarga de informes y análisis históricos</p>
                        </div>
                    </div>
                    <!-- Moved Generate button down to handle responsive wrapping -->
                </header>

                <div class="grid gap-4">
                    {REPORTS.map(report => (
                        <div class="flex items-center justify-between p-4 bg-[#121214] border border-white/5 rounded-xl hover:border-cyan-500/30 transition-colors group">
                            <div class="flex items-center gap-4">
                                <div class="p-3 bg-red-500/10 text-red-400 rounded-lg">
                                    <Icon name="lucide:file-text" class="w-6 h-6" />
                                </div>
                                <div>
                                    <h3 class="text-white font-medium group-hover:text-cyan-400 transition-colors">{report.title}</h3>
                                    <p class="text-xs text-gray-500">{report.date} • {report.size}</p>
                                </div>
                            </div>
                            <button class="p-2 text-gray-400 hover:text-white hover:bg-white/10 rounded-lg transition-colors">
                                <Icon name="lucide:download" class="w-5 h-5" />
                            </button>
                        </div>
                    ))}
                </div>
            </div>

            <!-- VIEW: SETTINGS (Admin Only Content) -->
            <div id="view-settings" class="hidden">
                <header class="flex flex-col sm:flex-row sm:items-center gap-3 justify-between mb-6 md:mb-8">
                    <div class="flex items-center gap-3">
                        <button id="menu-toggle-set" class="menu-toggle lg:hidden text-gray-400 hover:text-white p-1 rounded-md bg-white/5 border border-white/10">
                            <Icon name="lucide:menu" class="w-6 h-6" />
                        </button>
                    <div>
                        <h1 class="text-xl md:text-2xl font-bold text-white leading-tight">Configuración del Sistema</h1>
                        <p class="text-gray-400 text-xs md:text-sm mt-1">Gestión de usuarios y parámetros globales</p>
                    </div>
                </header>

                <div class="bg-gradient-to-r from-cyan-900/20 to-blue-900/20 border border-cyan-500/20 rounded-xl p-6">
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="text-lg font-semibold text-white flex items-center gap-2">
                            <Icon name="lucide:shield-alert" class="w-5 h-5 text-cyan-400" />
                            Panel de Administración
                        </h2>
                        <span class="text-xs px-2 py-1 bg-cyan-500/20 text-cyan-400 rounded border border-cyan-500/30">Modo Edición Activo</span>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <button class="p-4 bg-[#08080A] border border-white/10 rounded-lg text-left hover:border-cyan-500/50 transition-colors group">
                            <div class="flex items-center justify-between mb-2">
                                <Icon name="lucide:plus-circle" class="w-5 h-5 text-gray-400 group-hover:text-cyan-400" />
                                <span class="text-xs text-gray-500">Acción</span>
                            </div>
                            <span class="text-sm font-medium text-gray-300 group-hover:text-white">Agregar Nuevo Sensor</span>
                        </button>
                        <button class="p-4 bg-[#08080A] border border-white/10 rounded-lg text-left hover:border-cyan-500/50 transition-colors group">
                            <div class="flex items-center justify-between mb-2">
                                <Icon name="lucide:sliders" class="w-5 h-5 text-gray-400 group-hover:text-cyan-400" />
                                <span class="text-xs text-gray-500">Configuración</span>
                            </div>
                            <span class="text-sm font-medium text-gray-300 group-hover:text-white">Ajustar Umbrales de Alarma</span>
                        </button>
                        <button class="p-4 bg-[#08080A] border border-white/10 rounded-lg text-left hover:border-cyan-500/50 transition-colors group">
                            <div class="flex items-center justify-between mb-2">
                                <Icon name="lucide:users" class="w-5 h-5 text-gray-400 group-hover:text-cyan-400" />
                                <span class="text-xs text-gray-500">Usuarios</span>
                            </div>
                            <span class="text-sm font-medium text-gray-300 group-hover:text-white">Gestionar Accesos</span>
                        </button>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<script is:inline>
    // Dashboard Logic — Navegación, sesión y roles
    (function() {
        const sessionStr = localStorage.getItem('mbc_session');
        
        if (sessionStr) {
            const session = JSON.parse(sessionStr);
            const app = document.getElementById('dashboard-app');
            const userName = document.getElementById('user-name');
            const userRole = document.getElementById('user-role');
            const adminPanel = document.getElementById('admin-panel');
            const navSettings = document.getElementById('nav-settings');
            const adminButtons = document.querySelectorAll('.admin-only-btn');
            
            // Elementos del menú responsive
            const sidebar = document.getElementById('sidebar');
            const sidebarOverlay = document.getElementById('sidebar-overlay');
            const menuToggles = document.querySelectorAll('.menu-toggle');

            // Función para alternar sidebar móvil
            const toggleSidebar = () => {
                const isOpen = !sidebar.classList.contains('-translate-x-full');
                if (isOpen) {
                    sidebar.classList.add('-translate-x-full');
                    sidebarOverlay.classList.add('hidden');
                } else {
                    sidebar.classList.remove('-translate-x-full');
                    sidebarOverlay.classList.remove('hidden');
                }
            };

            // Event Listeners para el menú
            menuToggles.forEach(btn => btn.addEventListener('click', toggleSidebar));
            if (sidebarOverlay) sidebarOverlay.addEventListener('click', toggleSidebar);

            // Actualizar fecha y hora en tiempo real
            const updateTime = () => {
                const now = new Date();
                const timeString = now.toLocaleString('es-ES');
                document.querySelectorAll('.sensor-update-time').forEach(el => {
                    el.textContent = timeString;
                });
            };
            setInterval(updateTime, 1000);
            updateTime();

            // Show App
            if (app) {
                app.classList.remove('hidden');
                setTimeout(() => app.classList.remove('opacity-0'), 50);
            }

            // Set User Info
            if (userName) userName.textContent = session.user;
            if (userRole) userRole.textContent = session.role === 'admin' ? 'Administrador' : 'Visualizador';

            // Role Based Rendering
            if (session.role === 'admin') {
                if (adminPanel) adminPanel.classList.remove('hidden');
                if (navSettings) navSettings.classList.remove('hidden');
                adminButtons.forEach(btn => btn.classList.remove('hidden'));
            }

            // Logout Logic
            const logoutBtn = document.getElementById('logout-btn');
            if (logoutBtn) {
                logoutBtn.addEventListener('click', () => {
                    localStorage.removeItem('mbc_session');
                    window.location.href = '/login';
                });
            }

            // Navigation Logic
            const navItems = ['dashboard', 'monitoring', 'reports', 'settings'];
            
            navItems.forEach(id => {
                const btn = document.getElementById(`nav-${id}`);
                if (btn) {
                    btn.addEventListener('click', (e) => {
                        e.preventDefault();
                        
                        // Hide all views & Reset Nav
                        navItems.forEach(i => {
                            const v = document.getElementById(`view-${i}`);
                            const n = document.getElementById(`nav-${i}`);
                            if (v) v.classList.add('hidden');
                            if (n) {
                                n.classList.remove('bg-cyan-500/10', 'text-cyan-400', 'border', 'border-cyan-500/20');
                                n.classList.add('text-gray-400', 'hover:text-white', 'hover:bg-white/5');
                            }
                        });

                        // Show Target
                        document.getElementById(`view-${id}`)?.classList.remove('hidden');
                        btn.classList.remove('text-gray-400', 'hover:text-white', 'hover:bg-white/5');
                        btn.classList.add('bg-cyan-500/10', 'text-cyan-400', 'border', 'border-cyan-500/20');
                        
                        // En móviles, cerrar el sidebar al navegar
                        if (window.innerWidth < 1024 && !sidebar.classList.contains('-translate-x-full')) {
                            toggleSidebar();
                        }
                    });
                }
            });
        }
    })();
</script>