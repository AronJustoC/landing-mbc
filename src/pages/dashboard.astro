---
import Layout from '../layouts/Layout.astro';
import DashboardContent from '../components/dashboard.astro';
---

<Layout title="Dashboard | MBC" simpleLayout={true}>
    <DashboardContent title="Dashboard | MBC" />
</Layout>

<script>
    // Guard: redirige a /login si no hay sesión válida en Supabase
    import { getCurrentSession } from '../lib/authSession';

    (async () => {
        try {
            const session = await getCurrentSession();
            if (!session) {
                // Limpiar datos de perfil local si la sesión Supabase expiró
                localStorage.removeItem('mbc_session');
                throw new Error('no session');
            }
        } catch {
            window.location.replace('/login');
        }
    })();
</script>